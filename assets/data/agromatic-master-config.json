      "Q15",
      "Q20",
      "PF20",
      "PF25"
    ],
    "selectionField": "gearboxShaft",
    "onSelect": {
      "zg_q15": {
        "setActiveGearbox": "gearbox_q15_uploaded",
        "setActiveShaft": "shaft_q15_zusatzgetriebe",
        "setShaftMount": "underGearbox"
      },
      "zg_q20": {
        "setActiveGearbox": "gearbox_q20_uploaded",
        "setActiveShaft": "shaft_q20_zusatzgetriebe",
        "setShaftMount": "underGearbox"
      },
      "zg_pf20": {
        "setActiveGearbox": "gearbox_pf20_uploaded",
        "setActiveShaft": "shaft_pf20_zusatzgetriebe",
        "setShaftMount": "underGearbox"
      },
      "zg_pf25": {
        "setActiveGearbox": "gearbox_pf25_uploaded",
        "setActiveShaft": "shaft_pf25_zusatzgetriebe",
        "setShaftMount": "underGearbox"
      }
    },
