    "importNotes": [
      "Die hochgeladenen Zusatzgetriebe-JSONs wurden in gearboxVariants übernommen.",
      "Die Wellentypen Q15, Q20, PF20 und PF25 wurden als feste Entscheidungsvarianten in gearboxShaftVariants angelegt.",
      "Hinweis: Die hochgeladene Datei Q25.json wurde gemäß Nutzerwunsch als Option Q15 eingebunden; bei Bedarf Name/Key auf Q25 ändern.",
      "Hinweis: Die hochgeladene Datei zusatzPF15).json enthält intern ZusPF25 und wurde als PF25 eingebunden."
    ]
  },
  "decisionRules": {
    "gearboxMode": "fixedComboImage",
    "allowedGearboxShaftVariants": [
      "q20",
      "q25",
      "pf20",
